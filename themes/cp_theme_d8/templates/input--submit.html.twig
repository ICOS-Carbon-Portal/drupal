{#
/**
 * @file
 * Default theme implementation for an 'input' #type form element.
 *
 * Available variables:
 * - attributes: A list of HTML attributes for the input element.
 * - children: Optional additional rendered elements.
 *
 * @see\Drupal\Core\Form\FormPreprocess::preprocessInput()
 *
 * @ingroup themeable
 */
#}

{% set classAdd = "btn-secondary" %}
{% if attributes.value == "Submit" or attributes.value == "Apply" or attributes.value == "Update" %}
    {% set classAdd = "btn-primary" %}
{% elseif attributes.value == "Delete" %}
    {% set classAdd = "btn-warning" %}
{% endif %}

<input{{ attributes.addClass("btn w-auto border-0", classAdd).removeClass("form-submit", "button") }} />{{ children }}
