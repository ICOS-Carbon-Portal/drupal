{#
/**
 * @file
 * Theme implementation to display a full page width, two-column layout with a light blue background.
 *
 * Available variables:
 * - in_preview: Whether the plugin is being rendered in preview mode.
 * - content: The content for this layout.
 * - attributes: HTML attributes for the layout <div>.
 *
 * @ingroup themeable
 */
#}

{%
  set classes = [
    'layout',
    'layout--light-gray',
    'pt-' ~ (settings.spacing_top ?? 5),
    'pb-' ~ (settings.spacing_bottom ?? 5),
  ]
%}

{%
  set one_classes = [
    'layout__region',
    'layout__region--one',
    'col-lg',
    'px-0',
  ]
%}

{%
  set two_classes = [
    'layout__region',
    'layout__region--two',
    'col-lg',
    'px-0',
  ]
%}

{% if content %}
  <div{{ attributes.addClass(classes) }}>
    <div class="row justify-content-between gap-5">
      {% if content.one %}
        <div{{ region_attributes.one.addClass(one_classes) }}>
          {{ content.one }}
        </div>
      {% endif %}
      {% if content.two %}
        <div{{ region_attributes.two.addClass(two_classes) }}>
          {{ content.two }}
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}
