{#
/**
 * @file
 * Theme implementation to display a two-column layout using colored boxes and responsive flex layout.
 *
 * Available variables:
 * - in_preview: Whether the plugin is being rendered in preview mode.
 * - content: The content for this layout.
 * - attributes: HTML attributes for the layout <div>.
 *
 * @ingroup themeable
 */
#}

{%
  set classes = [
    'layout',
    'layout--colored-flex',
    'row',
    'justify-content-between',
    'gap-3',
  ]
%}

{%
  set left_classes = [
    'layout__region',
    'layout__region--left',
    'col-lg',
    'bg-primary',
    'text-light',
    'rounded',
  ]
%}

{%
  set right_classes = [
    'layout__region',
    'layout__region--right',
    'col-lg',
    'rounded',
  ]
%}

{% if content %}
  {% set rendered_left = content.left|render %}
  {% set rendered_right = content.right|render %}
  {% if rendered_left|trim or rendered_right|trim %}
  <div{{ attributes.addClass(classes) }}>
    {% if rendered_left|trim %}
      <div{{ region_attributes.left.addClass(left_classes) }}>
        {{ rendered_left }}
      </div>
    {% endif %}
    {% if rendered_right|trim %}
      <div{{ region_attributes.right.addClass(right_classes) }}>
        {{ rendered_right }}
      </div>
    {% endif %}
  </div>
  {% endif %}
{% endif %}
