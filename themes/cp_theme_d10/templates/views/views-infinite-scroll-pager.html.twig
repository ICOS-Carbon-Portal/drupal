{#
/**
 * @file
 * The views infinite scroll pager template.
 */
#}

{% if items.next %}
<div{{ attributes.addClass("d-flex justify-content-center") }}>
  <a class="btn btn-primary" href="{{ items.next.href }}" title="{{ 'Load more items'|t }}" rel="next">{{ options.button_text }}</a>
</div>
{% endif %}
